# Chrome extension / release packaging
# development | production
BOLHA_RELEASE_CHANNEL=development
# For production builds set this to your deployed HTTPS entitlement API origin, for example:
# BOLHA_EXTENSION_API_ORIGIN=https://api.example.com
BOLHA_EXTENSION_API_ORIGIN=

# Backend server
BOLHA_SERVER_BASE_URL=http://127.0.0.1:8787
BOLHA_PAYMENT_PROVIDER=mock
BOLHA_SIGNING_KEY_ID=dev-local-v1

# Optional for real Stripe mode:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
